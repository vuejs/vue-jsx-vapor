{
  "name": "@vue-jsx-vapor/runtime",
  "type": "module",
  "version": "3.2.19",
  "description": "Vue JSX Vapor Runtime",
  "license": "MIT",
  "homepage": "https://github.com/vuejs/vue-jsx-vapor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuejs/vue-jsx-vapor.git"
  },
  "bugs": {
    "url": "https://github.com/vuejs/vue-jsx-vapor/issues"
  },
  "keywords": [
    "vue",
    "jsx",
    "vapor",
    "runtime"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "jsx-vapor-dev": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./raw": {
      "types": "./dist/raw.d.ts",
      "jsx-vapor-dev": "./src/raw.ts",
      "import": "./dist/raw.js",
      "require": "./dist/raw.cjs"
    },
    "./*": "./*"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "DEV=true tsdown",
    "release": "bumpp && npm publish",
    "test": "vitest"
  },
  "peerDependencies": {
    "csstype": "^3.2.3",
    "vue": "catalog:"
  }
}
