    "release": "bumpp && npm publish",
    "test": "vitest"
  },
  "dependencies": {
    "@prettier/sync": "^0.6.1",
    "@typescript-eslint/utils": "^8.59.1"
  },
  "devDependencies": {
    "eslint-vitest-rule-tester": "^3.1.0"
  }
}
