    "ts-macro": "catalog:",
    "unplugin": "catalog:",
    "unplugin-utils": "catalog:"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/types": "^7.29.0",
    "@nuxt/kit": "catalog:",
    "@nuxt/schema": "catalog:",
